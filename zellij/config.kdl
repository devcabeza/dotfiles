// =============================================================================
// Zellij Config — tmux-style workflow
// =============================================================================

// --- General Settings ---
default_mode "normal"
default_layout "compact"
theme "gruvbox-dark"
scroll_buffer_size 50000
copy_command "wl-copy"
on_force_close "detach"

// =============================================================================
// KEYBINDINGS
//
// Philosophy:
//   Ctrl+t → tmux mode (prefix key, matching tmux)
//   Inside tmux mode: single keys for quick actions
//   Escape/Enter → returns to normal mode from any mode
//   Ctrl+s → scroll mode (the only remaining global shortcut)
//   All other Ctrl keys are free for programs (opencode, etc.)
// =============================================================================
keybinds clear-defaults=true {

    // ---------------------------------------------------------------------------
    // Tmux mode — entered via Ctrl+t
    // Single keys for fast workflow, no modifiers needed
    // ---------------------------------------------------------------------------
    tmux {
        // Navigation (vim-style)
        bind "h" { MoveFocus "left"; SwitchToMode "normal"; }
        bind "j" { MoveFocus "down"; SwitchToMode "normal"; }
        bind "k" { MoveFocus "up"; SwitchToMode "normal"; }
        bind "l" { MoveFocus "right"; SwitchToMode "normal"; }

        // Tab management
        bind "c" { NewTab; SwitchToMode "normal"; }
        bind "1" { GoToTab 1; SwitchToMode "normal"; }
        bind "2" { GoToTab 2; SwitchToMode "normal"; }
        bind "3" { GoToTab 3; SwitchToMode "normal"; }
        bind "4" { GoToTab 4; SwitchToMode "normal"; }
        bind "5" { GoToTab 5; SwitchToMode "normal"; }
        bind "6" { GoToTab 6; SwitchToMode "normal"; }
        bind "7" { GoToTab 7; SwitchToMode "normal"; }
        bind "8" { GoToTab 8; SwitchToMode "normal"; }
        bind "9" { GoToTab 9; SwitchToMode "normal"; }
        bind "p" { GoToPreviousTab; SwitchToMode "normal"; }
        bind "n" { GoToNextTab; SwitchToMode "normal"; }
        bind "," { SwitchToMode "renametab"; TabNameInput 0; }

        // Splits — new panes inherit current directory by default
        bind "\"" { NewPane "down"; SwitchToMode "normal"; }
        bind "-" { NewPane "down"; SwitchToMode "normal"; }
        bind "/" { NewPane "right"; SwitchToMode "normal"; }
        bind "%" { NewPane "right"; SwitchToMode "normal"; }

        // Pane management
        bind "x" { CloseFocus; SwitchToMode "normal"; }
        bind "z" { ToggleFocusFullscreen; SwitchToMode "normal"; }
        bind "f" { ToggleFloatingPanes; SwitchToMode "normal"; }

        // Apps in floating panes (scratchpads with toggle behavior)
        bind "g" {
            LaunchOrFocusPlugin "zellij-tools" {
                name "lazygit"
                args "scratchpad" "toggle" "lazygit"
            }
            SwitchToMode "normal";
        }
        bind "o" {
            LaunchOrFocusPlugin "zellij-tools" {
                name "opencode"
                args "scratchpad" "toggle" "opencode"
            }
            SwitchToMode "normal";
        }

        // Layout and scroll
        bind "Space" { NextSwapLayout; }
        bind "[" { SwitchToMode "scroll"; }

        // Session
        bind "d" { Detach; }

        // Resize (was Ctrl+n → resize mode)
        bind "H" { Resize "Decrease left"; SwitchToMode "normal"; }
        bind "J" { Resize "Decrease down"; SwitchToMode "normal"; }
        bind "K" { Resize "Decrease up"; SwitchToMode "normal"; }
        bind "L" { Resize "Decrease right"; SwitchToMode "normal"; }
        bind "=" { Resize "Increase"; SwitchToMode "normal"; }

        // Move pane (was Ctrl+h → move mode)
        bind "m" { SwitchToMode "move"; }

        // Close tab
        bind "X" { CloseTab; SwitchToMode "normal"; }

        // Session manager
        bind "s" {
            LaunchOrFocusPlugin "session-manager" {
                floating true;
                move_to_focused_tab true;
            }
            SwitchToMode "normal";
        }

        // Rename pane
        bind "." { SwitchToMode "renamepane"; PaneNameInput 0; }
    }

    // ---------------------------------------------------------------------------
    // Scroll mode — Ctrl+s from normal, [ from tmux mode
    // Vim-style navigation
    // ---------------------------------------------------------------------------
    scroll {
        bind "j" { ScrollDown; }
        bind "k" { ScrollUp; }
        bind "d" { HalfPageScrollDown; }
        bind "u" { HalfPageScrollUp; }
        bind "Ctrl f" { PageScrollDown; }
        bind "Ctrl b" { PageScrollUp; }
        bind "e" { EditScrollback; SwitchToMode "normal"; }
        bind "s" { SwitchToMode "entersearch"; SearchInput 0; }
    }

    // ---------------------------------------------------------------------------
    // Search mode — entered from scroll mode via s
    // ---------------------------------------------------------------------------
    search {
        bind "n" { Search "down"; }
        bind "p" { Search "up"; }
        bind "c" { SearchToggleOption "CaseSensitivity"; }
        bind "w" { SearchToggleOption "Wrap"; }
        bind "o" { SearchToggleOption "WholeWord"; }
    }

    entersearch {
        bind "Ctrl c" { SwitchToMode "scroll"; }
        bind "esc" { SwitchToMode "scroll"; }
        bind "enter" { SwitchToMode "search"; }
    }

    // ---------------------------------------------------------------------------
    // Move mode — entered from tmux mode via m
    // ---------------------------------------------------------------------------
    move {
        bind "h" { MovePane "left"; }
        bind "j" { MovePane "down"; }
        bind "k" { MovePane "up"; }
        bind "l" { MovePane "right"; }
        bind "left" { MovePane "left"; }
        bind "down" { MovePane "down"; }
        bind "up" { MovePane "up"; }
        bind "right" { MovePane "right"; }
        bind "n" { MovePane; }
        bind "p" { MovePaneBackwards; }
    }

    // ---------------------------------------------------------------------------
    // Rename modes
    // ---------------------------------------------------------------------------
    renametab {
        bind "esc" { UndoRenameTab; SwitchToMode "normal"; }
    }

    renamepane {
        bind "esc" { UndoRenamePane; SwitchToMode "normal"; }
    }

    // ---------------------------------------------------------------------------
    // Shared bindings across modes
    // ---------------------------------------------------------------------------

    // Escape and Enter return to normal mode (except in normal, entersearch, renametab, renamepane)
    shared_except "normal" "locked" "entersearch" "renametab" "renamepane" {
        bind "esc" { SwitchToMode "normal"; }
    }
    shared_except "normal" "locked" "entersearch" "renametab" "renamepane" {
        bind "enter" { SwitchToMode "normal"; }
    }

    // Ctrl+t enters tmux mode (the prefix)
    shared_except "locked" "scroll" "search" "tmux" {
        bind "Ctrl t" { SwitchToMode "tmux"; }
    }

    // Ctrl+s enters scroll mode
    shared_except "locked" "scroll" "search" {
        bind "Ctrl s" { SwitchToMode "scroll"; }
    }

    // Alt+scroll for resize anywhere (except locked)
    shared_except "locked" {
        bind "Alt +" { Resize "Increase"; }
        bind "Alt -" { Resize "Decrease"; }
        bind "Alt =" { Resize "Increase"; }
    }

    // Page scroll shared between scroll and search modes
    shared_among "scroll" "search" {
        bind "PageDown" { PageScrollDown; }
        bind "PageUp" { PageScrollUp; }
        bind "Ctrl c" { ScrollToBottom; SwitchToMode "normal"; }
        bind "Ctrl s" { SwitchToMode "normal"; }
    }

    // Ctrl+c/clear shared for rename modes
    shared_among "renametab" "renamepane" {
        bind "Ctrl c" { SwitchToMode "normal"; }
    }

    // Locked mode — Ctrl+g to unlock
    locked {
        bind "Ctrl g" { SwitchToMode "normal"; }
    }
}

// =============================================================================
// PLUGINS
// =============================================================================
plugins {
    about location="zellij:about"
    compact-bar location="zellij:compact-bar"
    configuration location="zellij:configuration"
    filepicker location="zellij:strider" {
        cwd "/"
    }
    plugin-manager location="zellij:plugin-manager"
    session-manager location="zellij:session-manager"
    status-bar location="zellij:status-bar"
    strider location="zellij:strider"
    tab-bar location="zellij:tab-bar"
    welcome-screen location="zellij:session-manager" {
        welcome_screen true
    }
    zellij-tools location="https://github.com/b0o/zellij-tools/releases/latest/download/zellij-tools.wasm" {
        scratchpads {
            lazygit {
                command "lazygit"
                width "80%"
                height "80%"
                origin "center"
                title "lazygit"
            }
            opencode {
                command "opencode"
                width "80%"
                height "80%"
                origin "center"
                title "opencode"
            }
        }
    }
}

load_plugins {
    zellij-tools
}
