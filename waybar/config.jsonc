{
    "layer": "top",
    "position": "top",
    "height": 32,
    "spacing": 6,
    "exclusive": true,
    "margin-top": 8,
    "margin-left": 12,
    "margin-right": 12,
    "margin-bottom": 0,

    "modules-left": ["hyprland/workspaces", "hyprland/window"],
    "modules-center": ["clock"],
    "modules-right": ["pulseaudio", "network", "bluetooth", "battery", "tray"],

    "hyprland/workspaces": {
        "format": "{icon}",
        "on-click": "activate",
        "format-icons": {
            "1": "َ°ژ¯",
            "2": "َ°ژ²",
            "3": "َ°ژ³",
            "4": "َ°ژ´",
            "5": "َ°ژµ",
            "6": "َ°ژ¶",
            "7": "َ°ژ·",
            "8": "َ°ژ¸",
            "9": "َ°ژ¹",
            "active": "َ°ژ¯",
            "default": "َ°ٹ "
        },
        "persistent-workspaces": {
            "*": 4
        },
        "all-outputs": false
    },

    "hyprland/window": {
        "format": "َ°£†  {}",
        "max-length": 50,
        "separate-outputs": true,
        "rewrite": {
            "(.*) â€” Mozilla Firefox": "َ°ˆ¹  $1",
            "(.*) â€” GNOME Terminal": "َ°»¾  $1"
        }
    },

    "clock": {
        "format": "َ°¥”  {:%H:%M}",
        "format-alt": "َ°¥”  {:%A, %d %B â€” %H:%M}",
        "tooltip-format": "<tt>{calendar}</tt>",
        "actions": {
            "on-click": "mode",
            "on-click-right": "mode"
        },
        "interval": 1
    },

    "pulseaudio": {
        "format": "{icon}  {volume}%",
        "format-muted": "َ°‌ں  Muted",
        "format-icons": {
            "headphone": "َ°‹‹ ",
            "hands-free": "َ°‹‹ ",
            "headset": "َ°‹‹ ",
            "phone": "ï‚• ",
            "portable": "ï‚• ",
            "car": "ï†¹ ",
            "default": ["َ°•؟ ", "َ°–€ ", "َ°•¾ "]
        },
        "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "on-click-right": "pavucontrol",
        "scroll-step": 5,
        "tooltip": false
    },

    "network": {
        "format-wifi": "َ°¤¨  {signalStrength}%",
        "format-ethernet": "َ°ˆ€  Ethernet",
        "format-disconnected": "َ°¤®  Offline",
        "on-click": "/home/alejandrocabeza/.dotfiles/scripts/wifi_menu.sh",
        "tooltip": false
    },

    "bluetooth": {
        "format": "َ°‚¯",
        "format-connected": "َ°‚±  {device_alias}",
        "format-connected-battery": "َ°‚±  {device_alias} {device_battery_percentage}%",
        "on-click": "/home/alejandrocabeza/.dotfiles/scripts/bluetooth_menu.sh",
        "tooltip": false
    },

    "battery": {
        "states": {
            "good": 95,
            "warning": 20,
            "critical": 10
        },
        "format": "{icon}  {capacity}%",
        "format-charging": "َ°‚„  {capacity}%",
        "format-full": "َ°پ¹  Full",
        "format-icons": ["َ°پ؛", "َ°پ»", "َ°پ¼", "َ°پ½", "َ°پ¾", "َ°پ؟", "َ°‚€", "َ°‚پ", "َ°‚‚", "َ°پ¹"],
        "on-click": "/home/alejandrocabeza/.dotfiles/scripts/wallpaper_picker.sh",
        "tooltip": false
    },

    "tray": {
        "icon-size": 14,
        "spacing": 4
    }
}
