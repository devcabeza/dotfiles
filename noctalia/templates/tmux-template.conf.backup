# Auto-generated by Noctalia — do not edit manually
set -g status-justify "left"
set -g status-style "bg={{colors.surface.default.hex}},fg={{colors.on_surface.default.hex}}"

set -g pane-border-style "fg={{colors.outline.default.hex}}"
set -g pane-active-border-style "fg={{colors.primary.default.hex}}"

set -g status-left-length "100"
set -g status-right-length "100"
set -g status-left "#[fg={{colors.surface.default.hex}},bg={{colors.primary.default.hex}},bold] #S #[fg={{colors.primary.default.hex}},bg={{colors.surface.default.hex}},nobold,nounderscore,noitalics]"
set -g status-right "#[fg={{colors.outline.default.hex}},bg={{colors.surface.default.hex}},nobold,nounderscore,noitalics]#[fg={{colors.on_surface_variant.default.hex}},bg={{colors.outline.default.hex}}] %Y-%m-%d  %H:%M #[fg={{colors.primary.default.hex}},bg={{colors.outline.default.hex}},nobold,nounderscore,noitalics]#[fg={{colors.surface.default.hex}},bg={{colors.primary.default.hex}},bold] #h "

setw -g window-status-activity-style "underscore,fg={{colors.on_surface_variant.default.hex}},bg={{colors.surface.default.hex}}"
setw -g window-status-separator ""
setw -g window-status-style "fg={{colors.on_surface_variant.default.hex}},bg={{colors.surface.default.hex}}"
setw -g window-status-format "#[fg={{colors.surface.default.hex}},bg={{colors.surface.default.hex}},nobold,nounderscore,noitalics]#[default] #I  #W #[fg={{colors.surface.default.hex}},bg={{colors.surface.default.hex}},nobold,nounderscore,noitalics]"
setw -g window-status-current-style "fg={{colors.on_surface.default.hex}},bg={{colors.surface_container_high.default.hex}}"
setw -g window-status-current-format "#[fg={{colors.surface.default.hex}},bg={{colors.surface_container_high.default.hex}},nobold,nounderscore,noitalics]#[fg={{colors.on_surface.default.hex}},bg={{colors.surface_container_high.default.hex}},bold] #I  #W #[fg={{colors.surface_container_high.default.hex}},bg={{colors.surface.default.hex}},nobold,nounderscore,noitalics]"
