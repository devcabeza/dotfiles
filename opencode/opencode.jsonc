{
  "$schema": "https://opencode.ai/config.json",
  "theme": "system",
  "autoupdate": false,
  "default_agent": "Ask",
  "instructions": [".agents/rules/*"],
  "agent": {
    "build": {
      "mode": "subagent",
      "hidden": true,
    },
    "plan": { "mode": "subagent", "hidden": true },
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}",
      },
      "enabled": true,
    },
    "stitch": {
      "type": "remote",
      "url": "https://stitch.googleapis.com/mcp",
      "enabled": true,
      "headers": {
        "X-Goog-Api-Key": "{env:GOOGLE_API_KEY}",
      },
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"],
      "enabled": true,
    },
    "engram": {
      "type": "local",
      "command": ["/home/alejandrocabeza/.nix-profile/bin/engram", "mcp"],
      "enabled": true,
      "environment": {
        "ENGRAM_DB_PATH": "/home/alejandrocabeza/.local/share/engram/engram.db",
        "LOG_LEVEL": "info",
      },
    },
  },
}
