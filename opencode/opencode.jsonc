{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "ask",
  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"],
      "enabled": true
    },
    "stitch": {
      "type": "remote",
      "url": "https://stitch.googleapis.com/mcp",
      "enabled": true,
      "headers": {
        "X-Goog-Api-Key": "${STITCH_API_KEY}"
      }
    },
    "engram": {
      "type": "local",
      "command": ["/home/alejandrocabeza/.nix-profile/bin/engram", "server"],
      "enabled": true,
      "environment": {
        "ENGRAM_DB_PATH": "/home/alejandrocabeza/.local/share/engram/engram.db",
        "LOG_LEVEL": "info"
      }
    }
  }
}
