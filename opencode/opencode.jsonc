{
  "$schema": "https://opencode.ai/config.json",
  "theme": "system",
  "autoupdate": false,
  "default_agent": "ask",
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{{CONTEXT7_API_KEY}}"
      },
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"],
      "enabled": true
    },
    "engram": {
      "type": "local",
      "command": ["/home/alejandrocabeza/.local/bin/engram", "mcp"],
      "enabled": true,
      "environment": {
        "ENGRAM_DB_PATH": "/home/alejandrocabeza/.local/share/engram/engram.db",
        "LOG_LEVEL": "info"
      }
    }
  }
}
