#!/usr/bin/env bash
# Wrapper to invoke Whisper for toggle or start/stop based dictation
# Requires whisper.cpp (whisper-cli), arecord, wtype, wl-copy/xclip, and pw-play/aplay.

# Ensure Nix and local bin directories are in the PATH
export PATH="/home/alejandrocabeza/.nix-profile/bin:/home/alejandrocabeza/.local/bin:$PATH"

WHISPER_BIN="/usr/bin/whisper-cli"
MODEL="/home/alejandrocabeza/.local/share/whisper-models/ggml-large-v3-turbo.bin"
INPUT_FILE="/tmp/whisper_input.wav"
OUTPUT_FILE="/tmp/whisper_output.txt"
PID_FILE="/tmp/whisper_dictation.pid"

# Sounds
START_SOUND="/usr/share/sounds/freedesktop/stereo/bell.oga"
STOP_SOUND="/usr/share/sounds/freedesktop/stereo/complete.oga"
ERROR_SOUND="/usr/share/sounds/freedesktop/stereo/dialog-warning.oga"

ACTION="${1:-toggle}"

play_sound() {
  local sound="$1"
  if [ -f "$sound" ]; then
    if command -v pw-play &>/dev/null; then
      pw-play "$sound" &
    elif command -v aplay &>/dev/null; then
      aplay -q "$sound" &
    fi
  fi
}

send_notification() {
  local title="$1"
  local msg="$2"
  if command -v notify-send &>/dev/null; then
    notify-send "$title" "$msg"
  fi
}

# Verify that the binary exists
if [ ! -x "$WHISPER_BIN" ]; then
  send_notification "Whisper Error" "whisper-cli binary not found at $WHISPER_BIN"
  echo "Error: whisper-cli binary not found at $WHISPER_BIN" >&2
  exit 1
fi

# Verify that the model file exists
if [ ! -f "$MODEL" ]; then
  send_notification "Whisper Error" "Model file not found at $MODEL"
  echo "Error: Model file not found at $MODEL" >&2
  exit 1
fi

start_recording() {
  # Check if already running
  if [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
    echo "Already recording."
    exit 0
  fi

  # Clean up old files
  rm -f "$INPUT_FILE"
  rm -f "$PID_FILE"
  
  # Play start sound and notify
  play_sound "$START_SOUND"
  send_notification "Whisper" "Recording started... Speak now. Release key to stop."
  
  # Start recording in the background
  arecord -f cd -t wav "$INPUT_FILE" < /dev/null >/dev/null 2>&1 &
  RECORD_PID=$!
  disown "$RECORD_PID"
  
  # Save PID
  echo "$RECORD_PID" > "$PID_FILE"
  echo "Recording started with PID $RECORD_PID"
}

stop_recording() {
  # Check if recording is running
  if [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
    RECORD_PID=$(cat "$PID_FILE")
    rm -f "$PID_FILE"
    
    # Kill arecord process gracefully
    kill "$RECORD_PID"
    wait "$RECORD_PID" 2>/dev/null || true
    
    play_sound "$STOP_SOUND"
    send_notification "Whisper" "Processing transcription..."
    
    # Clean old output file
    rm -f "$OUTPUT_FILE"
    
    # Run whisper inference
    $WHISPER_BIN -m "$MODEL" -l auto -f "$INPUT_FILE" -otxt -of "${OUTPUT_FILE%.txt}" >/dev/null 2>&1
    
    # Process output
    if [ -f "$OUTPUT_FILE" ]; then
      TRANSCRIPTION=$(cat "$OUTPUT_FILE" | xargs) # trim whitespace
      
      # Check if transcription is empty or just a hallucination (like "[BLANK_AUDIO]" or "Mario")
      if [ -n "$TRANSCRIPTION" ] && [ "$TRANSCRIPTION" != "[BLANK_AUDIO]" ] && [ "$TRANSCRIPTION" != "*Mario*" ]; then
        # Copy to clipboard
        if command -v wl-copy &>/dev/null; then
          wl-copy "$TRANSCRIPTION"
        elif command -v xclip &>/dev/null; then
          echo -n "$TRANSCRIPTION" | xclip -selection clipboard -i
        fi
        
        # Simulate keyboard typing into the active window
        if command -v wtype &>/dev/null; then
          sleep 0.2
          wtype "$TRANSCRIPTION"
        fi
        
        send_notification "Whisper" "Text copied and typed"
        echo "Transcription: $TRANSCRIPTION"
      else
        send_notification "Whisper" "No speech detected (or empty)"
        echo "Transcription was empty or noise."
      fi
    else
      play_sound "$ERROR_SOUND"
      send_notification "Whisper Error" "Failed to generate transcription."
      exit 1
    fi
  else
    echo "No active recording to stop."
  fi
}

case "$ACTION" in
  start)
    start_recording
    ;;
  stop)
    stop_recording
    ;;
  toggle)
    if [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
      stop_recording
    else
      start_recording
    fi
    ;;
  *)
    echo "Usage: $0 {start|stop|toggle}" >&2
    exit 1
    ;;
esac
