# Dunst - Gruvbox Material (Omarchy Style)
# Notificaciones al estilo Omarchy

[global]
    monitor = 0
    follow = mouse
    width = 320
    height = 300
    origin = top-right
    offset = 16x52
    scale = 0
    notification_limit = 5
    progress_bar = true
    progress_bar_height = 8
    progress_bar_frame_width = 1
    progress_bar_min_width = 150
    progress_bar_max_width = 300
    indicate_hidden = yes
    transparency = 5
    separator_height = 2
    padding = 16
    horizontal_padding = 16
    text_icon_padding = 8
    frame_width = 1
    frame_color = "#504945"
    separator_color = "frame"
    sort = yes
    font = "JetBrainsMono Nerd Font 10"
    line_height = 4
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    show_age_threshold = 60
    word_wrap = yes
    ellipsize = middle
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = yes
    icon_position = left
    min_icon_size = 24
    max_icon_size = 48
    icon_path = /usr/share/icons/Adwaita/32x32/status/:/usr/share/icons/Adwaita/32x32/devices/
    sticky_history = yes
    history_length = 20
    browser = /usr/bin/xdg-open
    always_run_script = true
    title = Dunst
    class = Dunst
    startup_notification = false
    vertical_alignment = center

[urgency_low]
    background = "#282828"
    foreground = "#a89984"
    timeout = 5
    highlight = "#7daea3"

[urgency_normal]
    background = "#282828"
    foreground = "#ddc7a1"
    timeout = 8
    highlight = "#a9b665"

[urgency_critical]
    background = "#282828"
    foreground = "#ea6962"
    timeout = 0
    highlight = "#ea6962"
