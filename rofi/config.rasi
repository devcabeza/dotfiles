@theme "gruvbox-dark-hard"

configuration {
    modi: "drun,run,window";
    show-icons: true;
    display-drun: "Apps";
    display-run: "Run";
    display-window: "Ventanas";
    icon-theme: "Papirus";
    terminal: "alacritty";
    kb-mode-next: "Shift+Tab";
    kb-mode-previous: "Tab";
    window-format: "{w} · {c} · {t}";
    drun-display-format: "{name}";
}
